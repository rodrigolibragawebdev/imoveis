{
  "name": "casa-em-pauta",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n API,WEB -c yellow,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "php -S localhost:5177 -t api api/index.php",
    "dev:web": "npm run dev -w frontend",
    "build": "npm run build -w frontend",
    "typecheck": "npm run typecheck -w frontend",
    "preview": "npm run preview -w frontend"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "overrides": {
    "typescript": "~5.9.3"
  }
}
