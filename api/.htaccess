RewriteEngine On
Options -Indexes
DirectoryIndex index.php

# Somente o ponto de entrada da API pode ser acessado pela web.
RewriteRule ^(?:bootstrap|database|preview)\.php$ - [F,L,NC]

# Rotas como /api/properties são encaminhadas ao router PHP.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
